# =============================================================================
# AI-Adaptive Honeypot Platform — Environment Variables
# Copy this file to .env and fill in production values
# NEVER commit .env to version control
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=honeypot
POSTGRES_USER=honeypot
# IMPORTANT: Change this before deploying to production!
POSTGRES_PASSWORD=changeme_in_production

# --- Logging ---
LOG_LEVEL=INFO

# --- Remote LLM Integration (Ngrok/Ollama) ---
# Default is local Ollama: http://host.docker.internal:11434/api/generate
LLM_URL=http://host.docker.internal:11434/api/generate
MODEL_NAME=qwen2.5:3b
